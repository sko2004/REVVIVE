# Copy this file to `.env` at the do-it repo root and fill in real values.
#   cp .env.example .env
# Never commit `.env` — it is listed in `.gitignore`.

# --- Vayu Vector DB (Qdrant) — Step 1 ---
QDRANT_URL=
QDRANT_API_KEY=
COLLECTION_NAME=
# QDRANT_PATH=
# QDRANT_PORT=

# --- Vayu Managed PostgreSQL — Step 2 ---
DATABASE_URL=
# POSTGRES_CONNECT_TIMEOUT=
# POSTGRES_CONNECT_RETRIES=

# --- Vayu Model as a Service — Step 3 ---
OPENAI_API_KEY=
OPENAI_BASE_URL=
CHAT_MODEL=
# AGENT_MAX_TOOL_LOOPS=

# --- Revvive external APIs ---
# Optional: used for route, weather, and charger lookup fallbacks.
GOOGLE_MAPS_API_KEY=
OPENROUTESERVICE_API_KEY=
WEATHER_API_KEY=
OPENCHARGEMAP_API_KEY=
